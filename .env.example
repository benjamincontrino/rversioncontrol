# =============================================================================
# .env.example — Safe to commit to GitHub. Copy this file to .env and fill
# in your actual credentials. NEVER put real values in this file.
# =============================================================================

# SQL SERVER
DB_DRIVER=ODBC Driver 17 for SQL Server
DB_SERVER=
DB_NAME=
DB_USER=
DB_PASSWORD=
DB_PORT=1433

# AZURE BLOB STORAGE
AZURE_STORAGE_ACCOUNT=
AZURE_STORAGE_KEY=
AZURE_CONTAINER=

# MICROSOFT FABRIC
FABRIC_DB_DRIVER=ODBC Driver 17 for SQL Server
FABRIC_DB_SERVER=
FABRIC_DB_NAME=
FABRIC_SERVER_NextGenStats=
FABRIC_SERVER_Predictions=
FABRIC_SERVER_RawData=

# DATABRICKS
DATABRICKS_HOST=
DATABRICKS_TOKEN=
DATABRICKS_SQL_WAREHOUSE_ID=
DATABRICKS_HTTP_PATH=
DATABRICKS_CATALOG=
DATABRICKS_SCHEMA=
DATABRICKS_SCHEMA_BRONZE=bronze
DATABRICKS_SCHEMA_SILVER=silver
DATABRICKS_SCHEMA_GOLD=gold

# SNOWFLAKE
